#!/bin/bash

PLUGIN_DIR="$CONFIG_DIR/plugins"
FONT_FACE="Roboto Condensed"
ICON_FONT="sketchybar-app-font:Regular:14.0"
NERD_FONT="Hack Nerd Font:Regular:14.0"

# --- Colors (matching waybar pywal-style palette) ---
BAR_COLOR=0x80000000
FOREGROUND=0xffffffff
INACTIVE=0xff928374
ACCENT=0xfff4d9e1
ALERT=0xffcc6666

# ──────────────────────────────────────────────
# Bar appearance — mirrors waybar top bar style
# ──────────────────────────────────────────────
sketchybar --bar \
  height=36 \
  blur_radius=30 \
  position=top \
  sticky=off \
  padding_left=12 \
  padding_right=12 \
  color=$BAR_COLOR \
  corner_radius=10 \
  y_offset=5 \
  margin=8 \
  shadow=on

# ──────────────────────────────────────────────
# Defaults
# ──────────────────────────────────────────────
sketchybar --default \
  icon.font="$NERD_FONT" \
  label.font="$FONT_FACE:Regular:13.0" \
  icon.color=$FOREGROUND \
  label.color=$FOREGROUND \
  icon.padding_left=6 \
  icon.padding_right=4 \
  label.padding_left=4 \
  label.padding_right=6 \
  background.padding_left=2 \
  background.padding_right=2

# ══════════════════════════════════════════════
# LEFT: AeroSpace workspaces
# ══════════════════════════════════════════════
for sid in $(aerospace list-workspaces --all); do
  sketchybar --add space space.$sid left \
    --set space.$sid \
      space=$sid \
      icon=$sid \
      icon.font="$FONT_FACE:Bold:13.0" \
      icon.color=$INACTIVE \
      icon.highlight_color=$ACCENT \
      icon.padding_left=8 \
      icon.padding_right=8 \
      label.drawing=off \
      background.drawing=off \
      click_script="aerospace workspace $sid" \
      script="$PLUGIN_DIR/aerospace.sh $sid"
done

sketchybar --add event aerospace_workspace_change

# Catch workspace changes from AeroSpace
sketchybar --add item aerospace_listener left \
  --set aerospace_listener \
    drawing=off \
    script="$PLUGIN_DIR/aerospace.sh" \
  --subscribe aerospace_listener aerospace_workspace_change

# ══════════════════════════════════════════════
# CENTER: Now-playing media
# ══════════════════════════════════════════════
sketchybar --add item media center \
  --set media \
    icon="󰎆" \
    icon.color=$ACCENT \
    label.max_chars=40 \
    scroll_texts=on \
    updates=on \
    script="$PLUGIN_DIR/media.sh" \
  --subscribe media media_change

# ══════════════════════════════════════════════
# RIGHT: system group, battery, network, volume, clock
# ══════════════════════════════════════════════

# --- CPU ---
sketchybar --add item cpu right \
  --set cpu \
    icon="󰻠" \
    update_freq=5 \
    script="$PLUGIN_DIR/cpu.sh"

# --- Memory ---
sketchybar --add item memory right \
  --set memory \
    icon="󰍛" \
    update_freq=5 \
    script="$PLUGIN_DIR/memory.sh"

# --- Disk ---
sketchybar --add item disk right \
  --set disk \
    icon="󰋊" \
    update_freq=60 \
    script="$PLUGIN_DIR/disk.sh"

# --- Clock (rightmost) ---
sketchybar --add item clock right \
  --set clock \
    icon="󰥔" \
    update_freq=30 \
    script="$PLUGIN_DIR/clock.sh"

# --- Battery ---
sketchybar --add item battery right \
  --set battery \
    update_freq=30 \
    script="$PLUGIN_DIR/battery.sh"

# --- Network ---
sketchybar --add item network right \
  --set network \
    icon="󰤨" \
    update_freq=10 \
    script="$PLUGIN_DIR/network.sh"

# --- Volume ---
sketchybar --add item volume right \
  --set volume \
    script="$PLUGIN_DIR/volume.sh" \
  --subscribe volume volume_change

# ──────────────────────────────────────────────
# Finalize
# ──────────────────────────────────────────────
sketchybar --update
