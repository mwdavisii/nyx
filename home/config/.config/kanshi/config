  exec hyprctl dispatch moveworkspacetomonitor 1 BOE 0x0BAA Unknown
  exec hyprctl dispatch moveworkspacetomonitor 2 BOE 0x0BAA Unknown
  exec hyprctl dispatch moveworkspacetomonitor 3 BOE 0x0BAA Unknown
}

